{
  "info": {
    "_postman_id": "taskflow-backend-api",
    "name": "TaskFlow Backend API",
    "description": "Complete API collection for TaskFlow Support Assistant Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Google OAuth Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"token\": \"eyJhbGciOiJSUzI1NiIsImtpZCI6IjExZTcyOTIwZjM1ODk0YWJlNmU4MTQ2MDhiMzAxZjI3ZTg2ZGQwMDYiLCJ0eXAiOiJKV1QifQ...\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/google",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "google"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Post Chat Question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"question\": \"How do I invite a team member?\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/chat",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "chat"]
            }
          }
        },
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/chat/history?limit=10&skip=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "chat", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "skip",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"question\": \"My laptop battery is draining fast\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/tickets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tickets"]
            }
          }
        },
        {
          "name": "Get All Tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/tickets?limit=50&skip=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tickets"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "skip",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Update Ticket Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"IN_PROGRESS\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/tickets/{{ticket_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tickets", "{{ticket_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["health"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
